# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Supabase now calls this a publishable key. Keep using this env name for the current app code.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Single-operator dashboard access gate
# Required before hosted deployment. Do not commit real values.
APP_ACCESS_PASSWORD=
APP_SESSION_SECRET=

# Optional AI provider
# Leave these blank for Claude Code assisted / manual content mode.
AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional WordPress draft queue
# WordPress is not required. Leave these blank unless you have a test site ready.
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# Optional official LinkedIn publishing
# Requires a LinkedIn Developer App with the Share on LinkedIn product.
# Keep all values server-side. Never prefix these with NEXT_PUBLIC_.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-host.example/api/linkedin/oauth/callback
LINKEDIN_OAUTH_SCOPES=w_member_social
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_URN=
LINKEDIN_API_VERSION=

# Optional official X / Twitter publishing
# Requires an X Developer App with OAuth 2.0 and/or OAuth 1.0a enabled.
# Keep all values server-side. Never prefix these with NEXT_PUBLIC_.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://affiliate-agent-os.vercel.app/api/auth/x/callback
X_OAUTH_SCOPES=tweet.write tweet.read users.read
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_API_ACCESS_READY=false
X_PROFILE_URL=https://x.com/your-handle
X_USERNAME=
X_DEVELOPER_ACCOUNT_URL=

# Optional official Pinterest publishing
# Requires Pinterest API access, an access token, and an authorized destination board.
# Keep all values server-side. Never prefix these with NEXT_PUBLIC_.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
PINTEREST_API_ACCESS_READY=false

# Optional official YouTube publishing connection
# Requires Google OAuth, YouTube Data API v3, a connected YouTube channel, and a real video asset.
# Keep all values server-side. Never prefix these with NEXT_PUBLIC_.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://affiliate-agent-os.vercel.app/api/auth/youtube/callback
YOUTUBE_OAUTH_SCOPES=https://www.googleapis.com/auth/youtube.upload https://www.googleapis.com/auth/youtube.readonly
YOUTUBE_API_ACCESS_READY=false
# Optional. If empty, APP_SESSION_SECRET is used to encrypt YouTube refresh tokens in server-side DB metadata.
YOUTUBE_TOKEN_ENCRYPTION_KEY=
YOUTUBE_PRIVACY_STATUS=public

# Safety overrides for controlled operator-only maintenance.
# Leave blank in normal use. These are intentionally verbose to prevent accidental approval/publishing.
AFFILIATE_AGENT_OS_ALLOW_BULK_APPROVAL=
AFFILIATE_AGENT_OS_BULK_APPROVAL_ACK=
AFFILIATE_AGENT_OS_ALLOW_DIRECT_PUBLISH=
AFFILIATE_AGENT_OS_DIRECT_PUBLISH_ACK=
