# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Supabase now calls this a publishable key. Keep using this env name for the current app code.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Single-operator dashboard access gate
# Required before hosted deployment. Do not commit real values.
APP_ACCESS_PASSWORD=
APP_SESSION_SECRET=

# Optional AI provider
# Leave these blank for Claude Code assisted / manual content mode.
AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional WordPress draft queue
# WordPress is not required. Leave these blank unless you have a test site ready.
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# Optional official LinkedIn publishing
# Requires a LinkedIn Developer App with the Share on LinkedIn product.
# Keep all values server-side. Never prefix these with NEXT_PUBLIC_.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-host.example/api/linkedin/oauth/callback
LINKEDIN_OAUTH_SCOPES=w_member_social
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_URN=
LINKEDIN_API_VERSION=
